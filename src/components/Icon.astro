---
/**
 * SVG icon library — minimal, line-based icons sized via font-size / `size` prop.
 * All icons inherit `currentColor`. Keep set small + cohesive.
 */
type IconName =
  | 'arrow-right' | 'arrow-up-right' | 'check' | 'shield' | 'document'
  | 'gauge' | 'clipboard' | 'handshake' | 'spark' | 'globe' | 'lock'
  | 'leaf' | 'beaker' | 'chip' | 'building' | 'truck' | 'utensils'
  | 'heart-pulse' | 'wrench' | 'pin' | 'phone' | 'mail' | 'clock'
  | 'linkedin' | 'plus' | 'minus' | 'menu' | 'close' | 'compass'
  | 'sparkles' | 'badge-check' | 'list-check' | 'route' | 'flag'
  | 'send' | 'chart' | 'users' | 'briefcase' | 'scale' | 'recycle';

type Props = { name: IconName; size?: number; class?: string; stroke?: number };
const { name, size = 20, class: className = '', stroke = 1.5 } = Astro.props as Props;

const paths: Record<IconName, string> = {
  'arrow-right': '<path d="M5 12h14M13 6l6 6-6 6" />',
  'arrow-up-right': '<path d="M7 17 17 7M9 7h8v8" />',
  'check': '<path d="M5 12.5l5 5L20 7" />',
