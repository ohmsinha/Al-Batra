  'lock': '<rect x="5" y="11" width="14" height="10" rx="2" /><path d="M8 11V8a4 4 0 0 1 8 0v3" />',
  'leaf': '<path d="M21 3c-7 0-13 5-13 12 0 3 1 5 3 6 7 0 12-5 12-13 0-2 0-4-2-5Z" /><path d="M5 21c2-6 6-9 11-12" />',
  'beaker': '<path d="M9 3h6M10 3v6L5 19a2 2 0 0 0 2 3h10a2 2 0 0 0 2-3L14 9V3" /><path d="M7 14h10" />',
  'chip': '<rect x="6" y="6" width="12" height="12" rx="2" /><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3" />',
  'building': '<rect x="4" y="3" width="16" height="18" rx="1" /><path d="M9 8h2M13 8h2M9 12h2M13 12h2M9 16h6" />',
