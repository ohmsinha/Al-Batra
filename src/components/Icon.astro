  'clipboard': '<rect x="6" y="4" width="12" height="17" rx="2" /><path d="M9 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1" /><path d="M9 11h6M9 15h4" />',
  'handshake': '<path d="m11 17 2 2a2.83 2.83 0 0 0 4-4l-7-7a3 3 0 0 0-3-1l-3 3 6 6" /><path d="m21 17-3-3 3-3" /><path d="m3 7 3 3-3 3" />',
  'spark': '<path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" />',
