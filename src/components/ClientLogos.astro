---
import SectionHead from './SectionHead.astro';
import Reveal from './Reveal.astro';
import Icon from './Icon.astro';

type Client = {
  name: string;
  industry: string;
  file: string;
};

const clients: Client[] = [
  { name: 'ADNOC',                        industry: 'Energy · Oil & Gas',      file: 'logo-adnoc.jpg' },
  { name: 'Etihad Airways',               industry: 'Aviation',                file: 'logo-etihad-airways.jpg' },
  { name: 'Shangri-La',                   industry: 'Hospitality',             file: 'logo-shangrila.jpg' },
  { name: 'Spinneys',                     industry: 'Retail · Grocery',        file: 'logo-spinneys.jpg' },
  { name: 'Medcare',                      industry: 'Healthcare',              file: 'logo-medcare.jpg' },
  { name: 'Millennium Hotel',             industry: 'Hospitality',             file: 'logo-millenium-hotel.jpg' },
  { name: 'Intercon DXB Marina',          industry: 'Hospitality · Marina',    file: 'logo-intercon-dxb-marina.jpg' },
  { name: 'Dubai Asset Management',       industry: 'Financial services',      file: 'logo-dubai-asset-mgmt.jpg' },
  { name: 'Fleetline Shipping',           industry: 'Logistics · Maritime',    file: 'logo-fleetline-shipping.jpg' },
  { name: 'Joseph Group',                 industry: 'Diversified group',       file: 'logo-joseph-group.jpg' },
  { name: 'Kingston Holding',             industry: 'Holding · Investment',    file: 'logo-kingston-holding.jpg' },
  { name: 'Al Bateel',                    industry: 'Retail · Trading',        file: 'logo-albateel.jpg' },
  { name: 'American Center',              industry: 'Education · Cultural',    file: 'logo-american-center.jpg' },
  { name: 'Rainbow Catering',             industry: 'Food service',            file: 'logo-rainbow-catering.jpg' },
  { name: 'Nasr Ceremonies',              industry: 'Events',                  file: 'logo-nasr-ceremonies.jpg' },
  { name: 'Universal Carlton Industries', industry: 'Manufacturing',           file: 'logo-univ-carlton-ind.jpg' },
  { name: 'Universal TSSC',              industry: 'Services',                 file: 'logo-univ-tssc.jpg' },
  { name: 'Global Emirates Services',    industry: 'General services',         file: 'logo-global-emirates-services-co.jpg' },
  { name: 'UHSHJ',                       industry: 'Healthcare',               file: 'logo-uhshj.jpg' },
];
---
<section class="ab-section" aria-labelledby="clients-served">
  <div class="ab-container">
    <Reveal>
      <SectionHead
        eyebrow="Selected clients"
        title="UAE organisations we have certified."
        lead="A selection of the 600+ organisations Al Batra has taken through ISO certification across the UAE — hospitality, healthcare, energy, manufacturing, retail, aviation and government-linked services."
        link={{ href: '/case-studies', label: 'Read case studies' }}
      />
    </Reveal>

    <div class="ab-logo-wall">
      {clients.map((c, i) => (
        <Reveal delay={Math.min(5, ((i % 4) + 1)) as 1|2|3|4|5}>
          <div class="ab-logo-tile" title={`${c.name} · ${c.industry}`}>
            <img
              src={`/clients/${c.file}`}
              alt={`${c.name} logo`}
              loading="lazy"
              decoding="async"
              class="ab-logo-tile__img"
            />
            <div class="ab-logo-tile__industry">{c.industry}</div>
          </div>
        </Reveal>
      ))}
      <Reveal delay={5}>
        <a href="/case-studies" class="ab-logo-tile ab-logo-tile--more" aria-label="And 580 more — read case studies">
          <span class="ab-logo-tile__plus" aria-hidden="true">
            <Icon name="arrow-up-right" size={20} />
          </span>
          <span class="ab-logo-tile__more-num">+ 580 more</span>
          <span class="ab-logo-tile__industry ab-logo-tile__industry--gold">Read case studies</span>
        </a>
      </Reveal>
    </div>

    <Reveal delay={2}>
      <div style="margin-top:28px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;font-size:13px;color:var(--ab-steel);justify-content:center;text-align:center;">
        <span style="font-family:var(--ab-font-mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;">A small selection · 19 of 600+</span>
        <span style="width:3px;height:3px;background:var(--ab-mute);border-radius:50%;"></span>
        <span>Published with client consent. Identity disclosure for confidential engagements available on NDA.</span>
      </div>
    </Reveal>
  </div>
</section>

<style>
  .ab-logo-wall {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border: 1px solid var(--ab-line-warm);
    border-radius: var(--ab-r-frame);
    overflow: hidden;
    background: #fff;
  }

  .ab-logo-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px 22px 20px;
    border-right: 1px solid var(--ab-line-warm);
    border-bottom: 1px solid var(--ab-line-warm);
    text-align: center;
    transition: background var(--ab-dur-base) var(--ab-ease-out);
    position: relative;
    min-height: 120px;
  }
  .ab-logo-tile:hover { background: var(--ab-sand); }

  .ab-logo-tile__img {
    max-width: 120px;
    max-height: 52px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) contrast(0.75);
    opacity: 0.75;
    transition: filter var(--ab-dur-base) var(--ab-ease-out),
                opacity var(--ab-dur-base) var(--ab-ease-out),
                transform var(--ab-dur-base) var(--ab-ease-out);
  }
  .ab-logo-tile:hover .ab-logo-tile__img {
    filter: grayscale(0%) contrast(1);
    opacity: 1;
    transform: scale(1.05);
  }

  .ab-logo-tile__industry {
    font-family: var(--ab-font-mono);
    font-size: 10px;
    color: var(--ab-mute);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.4;
    transition: color var(--ab-dur-base);
  }
  .ab-logo-tile:hover .ab-logo-tile__industry { color: var(--ab-steel); }

  /* "+ more" CTA tile */
  .ab-logo-tile--more {
    background: var(--ab-navy);
    cursor: pointer;
    text-decoration: none;
    gap: 8px;
  }
  .ab-logo-tile--more:hover { background: var(--ab-navy-deep); }

  .ab-logo-tile__plus {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.35);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: border-color var(--ab-dur-base), color var(--ab-dur-base);
  }
  .ab-logo-tile--more:hover .ab-logo-tile__plus {
    border-color: var(--ab-gold);
    color: var(--ab-gold);
  }

  .ab-logo-tile__more-num {
    font-family: var(--ab-font-display);
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.015em;
    line-height: 1;
  }

  .ab-logo-tile__industry--gold {
    color: var(--ab-gold) !important;
    opacity: 0.9;
  }
  .ab-logo-tile--more:hover .ab-logo-tile__industry--gold { opacity: 1; }

  /* Edge cleanup — 5-col */
  .ab-logo-tile:nth-child(5n) { border-right: 0; }
  .ab-logo-tile:nth-last-child(-n+5):nth-child(n+16) { border-bottom: 0; }

  /* Responsive */
  @media (max-width: 1024px) {
    .ab-logo-wall { grid-template-columns: repeat(4, 1fr); }
    .ab-logo-tile:nth-child(5n) { border-right: 1px solid var(--ab-line-warm); }
    .ab-logo-tile:nth-child(4n) { border-right: 0; }
    .ab-logo-tile:nth-last-child(-n+5):nth-child(n+16) { border-bottom: 1px solid var(--ab-line-warm); }
    .ab-logo-tile:nth-last-child(-n+4):nth-child(n+17) { border-bottom: 0; }
  }
  @media (max-width: 720px) {
    .ab-logo-wall { grid-template-columns: repeat(3, 1fr); }
    .ab-logo-tile:nth-child(4n) { border-right: 1px solid var(--ab-line-warm); }
    .ab-logo-tile:nth-child(3n) { border-right: 0; }
    .ab-logo-tile__img { max-width: 90px; max-height: 40px; }
  }
  @media (max-width: 480px) {
    .ab-logo-wall { grid-template-columns: repeat(2, 1fr); }
    .ab-logo-tile:nth-child(3n) { border-right: 1px solid var(--ab-line-warm); }
    .ab-logo-tile:nth-child(2n) { border-right: 0; }
  }
</style>
