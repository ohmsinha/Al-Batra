---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Reveal from '../components/Reveal.astro';
import Icon from '../components/Icon.astro';
import { company } from '../data/company';

const sections = [
  { id: 'collect',  title: 'Information we collect' },
  { id: 'use',      title: 'How we use the information' },
  { id: 'share',    title: 'Sharing' },
  { id: 'retain',   title: 'Retention' },
  { id: 'rights',   title: 'Your rights' },
  { id: 'contact',  title: 'Contact' },
];
---
<BaseLayout
  title="Privacy notice"
  description="How Al Batra Management Consultancy handles the personal information of website visitors and enquirers."
>
  <section class="ab-page-head" style="position:relative;overflow:hidden;">
    <div aria-hidden="true" class="ab-blueprint-fine" style="position:absolute;inset:0;opacity:.5;mask-image:radial-gradient(ellipse at 100% 0%, #000 0%, transparent 60%);-webkit-mask-image:radial-gradient(ellipse at 100% 0%, #000 0%, transparent 60%);"></div>
    <div class="ab-container ab-page-head-inner" style="position:relative;">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Privacy' }]} />
      <Reveal>
        <div style="margin-top:32px;max-width:820px;">
          <span class="ab-eyebrow-line">Privacy notice</span>
          <h1 class="ab-display ab-h1-page" style="text-wrap:balance;">How we handle the information you share with us.</h1>
          <p class="ab-lead" style="margin-top:20px;">
            This notice explains how {company.legalName} handles personal information collected through this website. It will be updated as the firm's data-protection practices evolve.
          </p>
        </div>
      </Reveal>
    </div>
  </section>

  <section class="ab-section">
    <div class="ab-container">
      <div class="ab-article-layout">
        <div>
          <Reveal>
            <article class="ab-prose">
              <h2 id="collect">Information we collect</h2>
              <p>We collect the information you provide through the contact and proposal-request forms — name, work email, telephone, company, the standard or industry you are enquiring about, and any context you choose to share in the message field. We also collect aggregated, non-identifying analytics about the pages visited on this website.</p>
              <h2 id="use">How we use the information</h2>
              <p>Information shared through the forms is used to respond to your enquiry, to scope and price a proposal where relevant, and to keep a record of the enquiry in our internal CRM. Analytics are used to improve the website.</p>
              <h2 id="share">Sharing</h2>
              <p>We do not sell or rent the information you share with us. Information is shared only with engagement-relevant Al Batra consultants and, where you have explicitly agreed, with a certification body or training authority you have asked us to coordinate with.</p>
              <h2 id="retain">Retention</h2>
              <p>Enquiry records are retained for the duration of any commercial engagement and for a reasonable period after, in line with UAE record-keeping expectations. You can ask us to delete your record at any time by writing to <a href={`mailto:${company.email}`}>{company.email}</a>.</p>
              <h2 id="rights">Your rights</h2>
              <p>You can ask to access, correct or delete the information we hold about you. Write to <a href={`mailto:${company.email}`}>{company.email}</a> with the subject line "Data request". We will respond within a reasonable working timeframe.</p>
              <h2 id="contact">Contact</h2>
              <p>For any privacy-related question, write to <a href={`mailto:${company.email}`}>{company.email}</a> or call <a href={`tel:${company.phones[0].tel}`}>{company.phones[0].display}</a>.</p>
              <p class="ab-meta" style="margin-top:48px;padding-top:24px;border-top:1px solid var(--ab-line-cool);font-size:12px;color:var(--ab-steel);">Last updated — to be confirmed with the client before launch.</p>
            </article>
          </Reveal>
        </div>
        <aside class="ab-toc">
          <div class="ab-toc__label">On this page</div>
          <ol>
            {sections.map((s) => <li><a href={`#${s.id}`}>{s.title}</a></li>)}
          </ol>
          <div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--ab-line-cool);">
            <div class="ab-toc__label" style="color:var(--ab-steel);">Questions?</div>
            <a href="/contact" class="ab-btn ab-btn-secondary" style="width:100%;justify-content:center;margin-top:8px;">
              Contact us <Icon name="arrow-right" size={14} />
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
