---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LeadCTA from '../../components/LeadCTA.astro';
import Reveal from '../../components/Reveal.astro';
import Icon from '../../components/Icon.astro';
import ImageSlot from '../../components/ImageSlot.astro';
import { standards } from '../../data/standards';
import { breadcrumbJsonLd } from '../../utils/seo';

export async function getStaticPaths() {
  const entries = await getCollection('industries');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'industries'> };
const { entry } = Astro.props as Props;
const { Content, headings } = await entry.render();
const data = entry.data;

const relatedServices = data.codes
  .map((code) => standards.find((s) => s.code === code))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));

const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'Industries', href: '/industries' },
  { name: data.title, href: `/industries/${entry.slug}` },
];

const sectorIcons: Record<string, string> = {
  hospitality: 'utensils',
  manufacturing: 'wrench',
  logistics: 'truck',
  healthcare: 'heart-pulse',
  energy: 'spark',
  'professional-services': 'briefcase',
};

const sectorPrompts: Record<string, string> = {
  hospitality: 'Editorial wide photo inside a UAE hotel kitchen — chef checking temperature log against an HACCP form. Warm directional light, document in focus.',
  manufacturing: 'Editorial photo inside a UAE manufacturing plant — operator in PPE reviewing an SOP on a clipboard. Soft daylight from a high window.',
  logistics: 'Editorial photo inside a UAE freight bay — clipboard manifest in foreground, container truck softly out of focus behind.',
  healthcare: 'Editorial photo inside a UAE diagnostic laboratory — calibration record on a tablet in foreground, lab benchwork in soft focus.',
  energy: 'Editorial photo at a UAE utility-scale solar site — operator reviewing an energy register tablet in front of panels at sunset.',
  'professional-services': 'Editorial photo of two UAE consultants reviewing a printed risk register on a glass conference table.',
};

const h2s = headings.filter((h) => h.depth === 2);

const jsonLd = [breadcrumbJsonLd(breadcrumbItems)];
---
<BaseLayout
  title={data.seoTitle ?? `${data.title} — ISO Certification in the UAE`}
  description={data.seoDescription ?? data.summary}
  jsonLd={jsonLd}
>
  <section class="ab-page-head" style="position:relative;overflow:hidden;">
    <div aria-hidden="true" class="ab-blueprint-fine" style="position:absolute;inset:0;opacity:.7;mask-image:radial-gradient(ellipse at 100% 0%, #000 0%, transparent 60%);-webkit-mask-image:radial-gradient(ellipse at 100% 0%, #000 0%, transparent 60%);"></div>
    <div class="ab-container ab-page-head-inner" style="position:relative;">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Industries', href: '/industries' },
        { label: data.title },
      ]} />
      <div class="ab-page-head-grid" style="margin-top:32px;">
        <Reveal>
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <span class="ab-disk gold"><Icon name={(sectorIcons[entry.slug] ?? 'building') as any} size={22} /></span>
            <span class="ab-tag">Industry practice</span>
          </div>
          <h1 class="ab-display ab-h1-page" style="text-wrap:balance;">{data.title}</h1>
          <p class="ab-lead" style="margin-top:20px;">{data.description}</p>
          <div style="display:flex;gap:12px;margin-top:32px;flex-wrap:wrap;">
            <a href="/contact" class="ab-btn ab-btn-primary">Discuss your operation <Icon name="arrow-right" size={14} /></a>
            <a href="#standards" class="ab-btn ab-btn-secondary">See applicable standards</a>
          </div>
        </Reveal>
        <Reveal delay={1}>
          <ImageSlot
            aspect="4-5"
            variant="navy"
            label="Sector visual"
            caption={data.title}
            prompt={sectorPrompts[entry.slug] ?? `Editorial photograph for the ${data.title} sector in the UAE.`}
          />
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Content with TOC -->
  <section class="ab-section">
    <div class="ab-container">
      <div class="ab-article-layout">
        <div>
          <Reveal>
            <article class="ab-prose">
              <Content />
            </article>
          </Reveal>
        </div>
        {h2s.length > 0 && (
          <aside class="ab-toc">
            <div class="ab-toc__label">On this page</div>
            <ol>
              {h2s.map((h) => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
            </ol>
            <div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--ab-line-cool);">
              <div class="ab-toc__label" style="color:var(--ab-steel);">Codes in scope</div>
              <div class="ab-pillbar" style="margin-top:8px;">
                {data.codes.map((c) => <span class="ab-pill">{c}</span>)}
              </div>
            </div>
          </aside>
        )}
      </div>
    </div>
  </section>

  {relatedServices.length > 0 && (
    <section class="ab-section ab-bg-sand" id="standards">
      <div class="ab-container">
        <Reveal>
          <div class="ab-eyebrow-line">Most-requested services in this sector</div>
          <h2 class="ab-display ab-h2" style="margin-bottom:40px;max-width:760px;">
            Standards we most commonly implement for {data.title.toLowerCase()} clients.
          </h2>
        </Reveal>
        <div class="ab-services-grid">
          {relatedServices.map((s, i) => (
            <Reveal delay={Math.min(5, (i + 1)) as 1|2|3|4|5}>
              {s.slug ? (
                <a class="ab-service-card" href={`/services/${s.slug}`}>
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
                    <span class="ab-disk gold"><Icon name="document" size={18} /></span>
                    <span class="ab-service-code">{s.code}</span>
                  </div>
                  <h3 class="ab-service-title" style="margin-top:18px;">{s.title}</h3>
                  <div style="flex:1;"></div>
                  <div class="ab-service-card-cta" style="display:flex;align-items:center;gap:6px;">Learn more <Icon name="arrow-right" size={14} /></div>
                </a>
              ) : (
                <a class="ab-service-card" href="/contact">
                  <span class="ab-service-code">{s.code}</span>
                  <h3 class="ab-service-title" style="margin-top:18px;">{s.title}</h3>
                  <div style="flex:1;"></div>
                  <div class="ab-service-card-cta">Ask the consulting team →</div>
                </a>
              )}
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <LeadCTA />
</BaseLayout>
