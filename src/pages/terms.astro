---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Reveal from '../components/Reveal.astro';
import Icon from '../components/Icon.astro';
import { company } from '../data/company';

const sections = [
  { id: 'content', title: 'Content' },
  { id: 'ip',      title: 'Intellectual property' },
  { id: 'liab',    title: 'Limitation of liability' },
  { id: 'law',     title: 'Governing law' },
];
---
<BaseLayout
  title="Terms of use"
  description="Terms of use for the Al Batra Management Consultancy website."
>
  <section class="ab-page-head" style="position:relative;overflow:hidden;">
    <div aria-hidden="true" class="ab-blueprint-fine" style="position:absolute;inset:0;opacity:.5;mask-image:radial-gradient(ellipse at 100% 0%, #000 0%, transparent 60%);-webkit-mask-image:radial-gradient(ellipse at 100% 0%, #000 0%, transparent 60%);"></div>
    <div class="ab-container ab-page-head-inner" style="position:relative;">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Terms' }]} />
      <Reveal>
        <div style="margin-top:32px;max-width:820px;">
          <span class="ab-eyebrow-line">Terms of use</span>
          <h1 class="ab-display ab-h1-page" style="text-wrap:balance;">Terms governing your use of this website.</h1>
          <p class="ab-lead" style="margin-top:20px;">
            These terms govern your use of the {company.legalName} website. By using the website you accept these terms. Final terms will be reviewed with the firm's legal counsel before launch.
          </p>
        </div>
      </Reveal>
    </div>
  </section>

  <section class="ab-section">
    <div class="ab-container">
      <div class="ab-article-layout">
        <div>
          <Reveal>
            <article class="ab-prose">
              <h2 id="content">Content</h2>
              <p>The information on this website is provided for general guidance. It does not constitute formal consulting advice, an offer to provide services, or a representation about specific ISO certification outcomes. For advice specific to your organisation, please engage the consultancy formally.</p>
              <h2 id="ip">Intellectual property</h2>
              <p>The content of this website — text, design, photography, the logo and the brand — is the intellectual property of {company.legalName} or its licensors. You may not reproduce or republish material from this website without written permission.</p>
              <h2 id="liab">Limitation of liability</h2>
              <p>While we take care to keep the website accurate and current, we make no warranties about completeness, accuracy or fitness for a particular purpose, to the extent permitted by UAE law.</p>
              <h2 id="law">Governing law</h2>
              <p>These terms are governed by the laws of the United Arab Emirates and the emirate of Sharjah.</p>
              <p class="ab-meta" style="margin-top:48px;padding-top:24px;border-top:1px solid var(--ab-line-cool);font-size:12px;color:var(--ab-steel);">Last updated — to be confirmed with the client before launch.</p>
            </article>
          </Reveal>
        </div>
        <aside class="ab-toc">
          <div class="ab-toc__label">On this page</div>
          <ol>
            {sections.map((s) => <li><a href={`#${s.id}`}>{s.title}</a></li>)}
          </ol>
          <div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--ab-line-cool);">
            <div class="ab-toc__label" style="color:var(--ab-steel);">Questions?</div>
            <a href="/contact" class="ab-btn ab-btn-secondary" style="width:100%;justify-content:center;margin-top:8px;">
              Contact us <Icon name="arrow-right" size={14} />
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
